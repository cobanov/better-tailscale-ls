#!/usr/bin/env bash
# tsls - colorful Tailscale device list
# Usage:
#   tsls              show your devices (Mullvad + shared-in nodes hidden)
#   tsls -o           online only
#   tsls -f           offline only
#   tsls -a           also show Mullvad exit nodes and shared-in (sharee) nodes
#   tsls -w [sec]     watch mode (default 5s refresh)
#   tsls -u           update to the latest release
#   tsls -V           print version

set -euo pipefail

VERSION="0.3.2"
REPO="cobanov/better-tailscale-ls"

ONLINE_ONLY=0
OFFLINE_ONLY=0
SHOW_ALL=0
WATCH=0
WATCH_INTERVAL=5

while [[ $# -gt 0 ]]; do
  case "$1" in
    -o|--online)  ONLINE_ONLY=1; shift ;;
    -f|--offline) OFFLINE_ONLY=1; shift ;;
    -a|--all)     SHOW_ALL=1; shift ;;
    -w|--watch)
      WATCH=1; shift
      if [[ ${1:-} =~ ^[0-9]+$ ]]; then WATCH_INTERVAL=$1; shift; fi
      ;;
    -u|--update|--upgrade) ACTION=update; shift ;;
    -V|--version) printf "tsls %s\n" "$VERSION"; exit 0 ;;
    -h|--help)
      sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done
ACTION="${ACTION:-}"

command -v tailscale >/dev/null || { echo "tailscale not found in PATH" >&2; exit 1; }
command -v jq >/dev/null || { echo "jq not found in PATH (brew install jq)" >&2; exit 1; }

# ANSI helpers — balanced palette inspired by One Dark / Gruvbox
if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'; C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'
  C_GREEN=$'\033[38;5;114m'    # green
  C_RED=$'\033[38;5;168m'      # rose
  C_YELLOW=$'\033[38;5;179m'   # gold
  C_BLUE=$'\033[38;5;111m'     # sapphire
  C_MAGENTA=$'\033[38;5;141m'  # purple
  C_CYAN=$'\033[38;5;80m'      # cyan
  C_GREY=$'\033[38;5;245m'     # grey
  C_ORANGE=$'\033[38;5;215m'   # peach
else
  C_RESET=""; C_DIM=""; C_BOLD=""; C_GREEN=""; C_RED=""; C_YELLOW=""
  C_BLUE=""; C_MAGENTA=""; C_CYAN=""; C_GREY=""; C_ORANGE=""
fi

os_color() {
  case "$1" in
    macOS|iOS)        printf "%s" "$C_CYAN" ;;
    linux)            printf "%s" "$C_YELLOW" ;;
    windows)          printf "%s" "$C_BLUE" ;;
    android)          printf "%s" "$C_GREEN" ;;
    tvOS|FreeBSD|*)   printf "%s" "$C_MAGENTA" ;;
  esac
}

human_ago() {
  # input: ISO timestamp or 0001-01-01T...; output: "5m", "3h", "2d"
  local ts="$1"
  [[ "$ts" == 0001-01-01* || -z "$ts" ]] && { printf "now"; return; }
  local now epoch diff
  now=$(date +%s)
  # macOS date can't parse fractional ISO directly; strip fraction & Z
  local clean="${ts%%.*}"
  clean="${clean%Z}"
  epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%S" "$clean" +%s 2>/dev/null || echo "$now")
  diff=$(( now - epoch ))
  if   (( diff < 60 ));     then printf "%ds" "$diff"
  elif (( diff < 3600 ));   then printf "%dm" $((diff/60))
  elif (( diff < 86400 ));  then printf "%dh" $((diff/3600))
  elif (( diff < 2592000 ));then printf "%dd" $((diff/86400))
  else printf "%dmo" $((diff/2592000))
  fi
}

resolve_self() {
  # Follow symlinks to find the actual on-disk script path.
  local p="$0"
  while [[ -L "$p" ]]; do
    local t
    t=$(readlink "$p")
    [[ "$t" = /* ]] && p="$t" || p="$(cd "$(dirname "$p")" && pwd)/$t"
  done
  printf "%s\n" "$p"
}

self_update() {
  command -v curl >/dev/null || { echo "curl required for --update" >&2; exit 1; }
  local self tmp tag remote dl_url
  self=$(resolve_self)
  tmp=$(mktemp)

  printf "\n  %scurrent:%s %s\n" "$C_DIM" "$C_RESET" "$VERSION"
  printf "  %schecking:%s github.com/%s releases\n" "$C_DIM" "$C_RESET" "$REPO"

  # Resolve the latest release tag via the GitHub API. Release/tag URLs
  # are immutable, so raw.githubusercontent.com always serves them fresh
  # (unlike branch-based URLs, which the CDN caches aggressively).
  tag=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | grep -m1 '"tag_name":' \
        | sed -E 's/.*"tag_name"[^"]*"([^"]+)".*/\1/')

  if [[ -z "$tag" ]]; then
    rm -f "$tmp"
    printf "  %s✗%s could not determine latest release (no releases yet?)\n" \
      "$C_RED" "$C_RESET" >&2
    exit 1
  fi

  remote="${tag#v}"

  if [[ "$remote" == "$VERSION" ]]; then
    rm -f "$tmp"
    printf "  %s✓%s already on the latest version (%s)\n\n" \
      "$C_GREEN" "$C_RESET" "$VERSION"
    exit 0
  fi

  printf "  %s↑%s updating %s%s%s → %s%s%s\n" \
    "$C_GREEN" "$C_RESET" \
    "$C_DIM" "$VERSION" "$C_RESET" \
    "$C_BOLD" "$remote" "$C_RESET"

  dl_url="https://raw.githubusercontent.com/${REPO}/${tag}/tsls"
  if ! curl -fsSL "$dl_url" -o "$tmp"; then
    rm -f "$tmp"
    printf "  %s✗%s download failed: %s\n" "$C_RED" "$C_RESET" "$dl_url" >&2
    exit 1
  fi

  # Sanity check: the downloaded file should at least look like our script
  if ! head -1 "$tmp" | grep -q '^#!/usr/bin/env bash'; then
    rm -f "$tmp"
    printf "  %s✗%s downloaded file looks corrupted\n" "$C_RED" "$C_RESET" >&2
    exit 1
  fi

  if [[ -w "$self" ]]; then
    install -m 0755 "$tmp" "$self"
  else
    printf "  %sneed sudo to write %s%s\n" "$C_DIM" "$self" "$C_RESET"
    sudo install -m 0755 "$tmp" "$self"
  fi
  rm -f "$tmp"
  printf "  %s✓%s installed v%s at %s\n\n" "$C_GREEN" "$C_RESET" "$remote" "$self"
}

render() {
  local json
  json=$(tailscale status --json 2>/dev/null)

  local tailnet
  tailnet=$(printf "%s" "$json" | jq -r '.MagicDNSSuffix // "tailnet"')

  # Build rows separated by \x1f (Unit Separator, non-whitespace so bash
  # `read` won't collapse empty fields the way it does with tabs).
  # Columns: online<US>hidden<US>name<US>ip<US>os<US>last<US>tag<US>caps
  # `hidden` flags noise we suppress by default without dropping the row:
  # Mullvad-tagged exit nodes and ShareeNode entries (devices owned by
  # users we've shared a node *to* — Tailscale masks these behind the
  # placeholder hostname "device-of-shared-to-user"). "name" is the Tailscale
  # machine name (DNSName before first dot); falls back to HostName.
  # `caps` is a comma-separated list of capability flags: exit-opt, subnets.
  local US=$'\x1f'
  local rows
  rows=$(printf "%s" "$json" | jq -r --arg us "$US" '
    [ .Self ] + ( .Peer // {} | to_entries | map(.value) )
    | .[]
    | ( (.DNSName // "") | split(".") | .[0] ) as $name
    | ( (.Tags // []) | any(startswith("tag:mullvad")) ) as $is_mullvad
    | ( .ShareeNode // false ) as $is_sharee
    | ( .ID == ($self // "") ) as $is_self
    | [
        (if .Online then "1" else "0" end),
        (if ($is_mullvad or $is_sharee) then "1" else "0" end),
        (if ($name // "") == "" then (.HostName // "?") else $name end),
        (.TailscaleIPs[0] // "-"),
        (if (.OS // "") == "" then "-" else .OS end),
        (.LastSeen // "0001-01-01T00:00:00Z"),
        (if $is_self then "self"
         elif .ExitNode then "exit"
         elif .Active then "active"
         else "" end),
        ([
          (if (.ExitNodeOption // false) and (.ExitNode // false | not) then "exit-opt" else empty end),
          (if ((.PrimaryRoutes // []) | length) > 0 then "subnets" else empty end)
        ] | join(","))
      ] | join($us)
  ' --arg self "$(printf "%s" "$json" | jq -r '.Self.ID')")

  # Counts (visible-only respect SHOW_ALL)
  local total online offline hidden
  total=$(printf "%s\n" "$rows" | grep -c . || true)
  hidden=$(printf "%s\n" "$rows" | awk -F"$US" '$2=="1"' | wc -l | tr -d ' ')
  if [[ "$SHOW_ALL" == 1 ]]; then
    online=$(printf "%s\n" "$rows" | awk -F"$US" '$1=="1"' | wc -l | tr -d ' ')
    offline=$(( total - online ))
  else
    online=$(printf "%s\n" "$rows"  | awk -F"$US" '$1=="1" && $2=="0"' | wc -l | tr -d ' ')
    offline=$(printf "%s\n" "$rows" | awk -F"$US" '$1=="0" && $2=="0"' | wc -l | tr -d ' ')
  fi

  printf "\n  %s%sTailscale%s  %s%s%s  ·  %s%s online%s  %s%s offline%s" \
    "$C_BOLD" "$C_CYAN" "$C_RESET" \
    "$C_DIM" "$tailnet" "$C_RESET" \
    "$C_GREEN" "$online" "$C_RESET" \
    "$C_GREY"  "$offline" "$C_RESET"
  if [[ "$SHOW_ALL" != 1 && "$hidden" -gt 0 ]]; then
    printf "  ·  %s%s hidden%s" "$C_DIM" "$hidden" "$C_RESET"
  fi
  printf "   %sv%s%s\n" "$C_DIM" "$VERSION" "$C_RESET"
  # Match the actual table width: ip(15) + name(18) + os(8) + status
  # column + a little slack for badges, capped at terminal width.
  local cols width
  cols=$(tput cols 2>/dev/null || echo 80)
  width=$(( cols - 4 ))
  (( width > 68 )) && width=68
  (( width < 20 )) && width=20
  printf "  %s%s%s\n" "$C_DIM" "$(printf '─%.0s' $(seq 1 "$width"))" "$C_RESET"

  # Sort: online (1) first, then by name
  local sorted
  sorted=$(printf "%s" "$rows" | LC_ALL=C sort -t"$US" -k1,1r -k3,3)

  while IFS="$US" read -r is_online is_hidden name ip os last tag caps; do
    [[ -z "$name" ]] && continue
    if [[ "$SHOW_ALL" != 1 && "$is_hidden" == "1" ]]; then continue; fi
    if [[ "$ONLINE_ONLY" == 1 && "$is_online" != "1" ]]; then continue; fi
    if [[ "$OFFLINE_ONLY" == 1 && "$is_online" != "0" ]]; then continue; fi

    local dot status_col status_txt
    if [[ "$is_online" == "1" ]]; then
      dot="${C_GREEN}●${C_RESET}"
      status_col="$C_GREEN"; status_txt="online"
    else
      dot="${C_GREY}○${C_RESET}"
      status_col="$C_GREY"; status_txt="$(human_ago "$last") ago"
    fi

    local osc
    osc=$(os_color "$os")

    local badge=""
    case "$tag" in
      self)   badge=" ${C_DIM}[self]${C_RESET}" ;;
      exit)   badge=" ${C_ORANGE}[exit]${C_RESET}" ;;
      active) badge=" ${C_GREEN}[active]${C_RESET}" ;;
    esac
    if [[ -n "$caps" ]]; then
      local cap
      while IFS= read -r cap; do
        [[ -z "$cap" ]] && continue
        case "$cap" in
          exit-opt) badge+=" ${C_DIM}[exit?]${C_RESET}" ;;
          subnets)  badge+=" ${C_BLUE}[subnets]${C_RESET}" ;;
        esac
      done < <(printf "%s\n" "$caps" | tr ',' '\n')
    fi

    # 15-char ip, 18-char name, 8-char os, status
    printf "  %s  %s%-15s%s  %s%-18s%s  %s%-8s%s  %s%s%s%s\n" \
      "$dot" \
      "$C_DIM"  "$ip"   "$C_RESET" \
      "$C_BOLD" "$name" "$C_RESET" \
      "$osc"    "$os"   "$C_RESET" \
      "$status_col" "$status_txt" "$C_RESET" \
      "$badge"
  done <<< "$sorted"

  printf "\n"
}

if [[ "$ACTION" == "update" ]]; then
  self_update
elif [[ "$WATCH" == 1 ]]; then
  trap 'tput cnorm 2>/dev/null; exit 0' INT TERM
  tput civis 2>/dev/null || true
  while true; do
    clear
    render
    printf "  %srefreshing every %ss · ctrl-c to quit%s\n" "$C_DIM" "$WATCH_INTERVAL" "$C_RESET"
    sleep "$WATCH_INTERVAL"
  done
else
  render
fi
